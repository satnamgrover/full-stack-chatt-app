pipeline {
    agent any

    stages {
        stage('PUll Code') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/satnamgrover/full-stack-chatt-app.git'
            }
        }
        stage('build'){
            steps {
                sh "docker build -t frontend ./frontend/Dockerfile"
                sh "docker build -t backend ./backend/Dockerfile"
            }
        }
        stage('deploy'){
            steps {
                sh "docker-compose up --build -d"
            }
        }
    }
}

